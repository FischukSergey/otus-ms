# Keycloak Environment Variables Example
# Скопируйте этот файл в .env и заполните реальными значениями
# НЕ коммитьте .env файл в git!

# PostgreSQL Configuration
KEYCLOAK_DB_PASSWORD=CHANGE_ME_strong_password_123

# Keycloak Admin User
# ВАЖНО: Используется ТОЛЬКО при первом запуске для создания admin
# При последующих запусках игнорируется - пароль берется из БД
# Для смены пароля используйте Admin Console, а не .env файл
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password_456

# Keycloak Hostname
# ВАЖНО: Только домен БЕЗ протокола и пути
# Протокол и путь указываются в docker-compose через KC_HOSTNAME_URL
KEYCLOAK_HOSTNAME=yourdomain.com
# Или если используете IP:
# KEYCLOAK_HOSTNAME=192.168.1.100
# 
# Keycloak будет доступен: https://yourdomain.com/auth/
